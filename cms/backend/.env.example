# ─── Database ───────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/nua_cms"

# ─── JWT Secrets (generate with: openssl rand -hex 64) ──────
JWT_ACCESS_SECRET="replace_with_64_byte_random_hex"
JWT_REFRESH_SECRET="replace_with_different_64_byte_random_hex"

# ─── CSRF ────────────────────────────────────────────────────
CSRF_SECRET="replace_with_64_byte_random_hex"

# ─── Cloudinary (media uploads) ──────────────────────────────
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# ─── App ─────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL="http://localhost:3000"
ADMIN_URL="http://localhost:3002"

# ─── First Admin Account (used in seed only) ─────────────────
SEED_ADMIN_EMAIL="admin@nua.com"
SEED_ADMIN_PASSWORD="change_this_immediately"
