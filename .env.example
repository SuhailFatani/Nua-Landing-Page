# ─────────────────────────────────────────────────────────────────────────────
# Nua Security — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Neo4j ────────────────────────────────────────────────────────────────────
NEO4J_PASSWORD=change_this_secure_password
# Used inside Docker Compose: bolt://neo4j:<NEO4J_PASSWORD>@neo4j:7687
# Used outside Docker (direct): bolt://neo4j:<NEO4J_PASSWORD>@localhost:7687

# ── Django Backend ───────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=replace_with_50_char_random_string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

# JWT — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace_with_64_byte_random_hex
JWT_REFRESH_SECRET=replace_with_different_64_byte_random_hex

# IP hashing salt (GDPR-safe analytics)
IP_HASH_SALT=replace_with_random_string

# ── Cloudinary (Media Storage) ───────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── CORS ─────────────────────────────────────────────────────────────────────
# For development:
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3000
# For production (comma-separated):
CORS_ALLOWED_ORIGINS=https://nuasecurity.com,https://www.nuasecurity.com

# ── Seed Admin Account ───────────────────────────────────────────────────────
SEED_ADMIN_EMAIL=admin@nuasecurity.com
SEED_ADMIN_PASSWORD=change_this_immediately

# ── Next.js Frontend ─────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Production Only ─────────────────────────────────────────────────────────
# ALLOWED_HOSTS=api.nuasecurity.com,backend
# API_URL=https://api.nuasecurity.com
# SITE_URL=https://nuasecurity.com
